#!/usr/bin/env node
const fs = require('fs');
const path = process.env.MOCK_ARGS_FILE;
fs.writeFileSync(path, JSON.stringify(process.argv.slice(2)));
let buf='';
process.stdin.setEncoding('utf8');
process.stdin.on('data', chunk=>{buf += chunk; if(buf.includes('
')){
  const line=buf.split('
')[0];
  try { JSON.parse(line); } catch {}
  process.stdout.write(JSON.stringify({type:'response',command:'prompt',success:true})+'
');
  process.stdout.write(JSON.stringify({type:'tool_execution_start',toolName:'bash',args:{command:'echo hi',OPENAI_API_KEY:'secret'}})+'
');
  process.stdout.write(JSON.stringify({type:'message_end',message:{usage:{input:1,output:2,cacheRead:3,cacheWrite:4,cost:{total:0.1}}}})+'
');
  process.stdout.write(JSON.stringify({type:'agent_end'})+'
');
  process.exit(0);
}});
